# Supabase project URL — visible in Project Settings > API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key — safe to expose to the browser; RLS enforces data access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — server-only. NEVER expose this to the browser.
# Only needed for admin operations (e.g. seed scripts). Not used in H2.
SUPABASE_SERVICE_ROLE_KEY=
